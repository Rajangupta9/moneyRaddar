# RupeeRadar backend configuration
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# Groq API key (server-side only — never expose to the frontend).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Model used across the project (categorization + insights).
# Per project decision, RupeeRadar uses Groq. Default: Llama 3.3 70B Versatile.
# For high-volume categorization you may switch to: llama-3.1-8b-instant
RUPEERADAR_LLM_MODEL=llama-3.3-70b-versatile

# Optional: override the Groq API base URL (leave unset for the default).
# GROQ_BASE_URL=https://api.groq.com

# CORS: comma-separated list of allowed frontend origins (Vite dev default).
RUPEERADAR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload size cap in megabytes (guards Stage 1 ingest).
RUPEERADAR_MAX_UPLOAD_MB=10
